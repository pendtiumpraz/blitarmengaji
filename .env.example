# ============================================================
# Blitar Mengaji — Contoh Environment Variables
# Salin file ini menjadi `.env.local` lalu isi nilainya.
# JANGAN commit .env.local ke git.
# ============================================================

# Koneksi Neon Postgres (serverless). Ambil dari dashboard Neon > Connection string.
# Pastikan extension pgvector di-enable: CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL=

# Secret untuk NextAuth (enkripsi JWT/session). Generate: `openssl rand -base64 32`
NEXTAUTH_SECRET=

# URL aplikasi (untuk callback NextAuth). Lokal = http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (OPSIONAL). Login Google hanya aktif bila KEDUANYA terisi.
# Ambil dari Google Cloud Console > APIs & Services > Credentials (OAuth client ID).
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Token baca/tulis Vercel Blob (storage foto/PDF/poster). Ambil dari dashboard Vercel.
BLOB_READ_WRITE_TOKEN=

# API key DeepSeek (AI Assistant / RAG). Ambil dari platform DeepSeek.
DEEPSEEK_API_KEY=

# Email Super Admin awal (dipakai saat seed).
SUPERADMIN_EMAIL=

# Password Super Admin awal (dipakai saat seed). GANTI setelah login pertama.
SUPERADMIN_PASSWORD=

# URL publik produksi (untuk sitemap, robots, OpenGraph, TWA). Lokal = http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Tautan file APK (.apk). Bila diisi → tombol & banner "Unduh APK" aktif di situs.
NEXT_PUBLIC_APK_URL=

# TWA / APK (lihat docs/APK-BUILD-GUIDE.md). Untuk /.well-known/assetlinks.json.
TWA_PACKAGE_NAME=com.blitarmengaji.twa
TWA_SHA256=

# Kunci enkripsi token storage & API key AI (AES-256-GCM). Generate: hex 32 byte (64 char).
STORAGE_ENC_KEY=
